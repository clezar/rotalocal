rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL, role, createdAt
    //
    // Collection: episodes
    // Fields: title, description, videoUrl, thumbnailUrl, category, businessId, publishedAt
    //
    // Collection: businesses
    // Fields: name, description, category, address, phone, whatsapp, instagram, website, logoUrl, coverUrl, gallery
    //
    // Collection: blogPosts
    // Fields: title, content, author, thumbnailUrl, publishedAt, tags
    //
    // Collection: commercialRequests
    // Fields: name, businessName, email, whatsapp, message, status, createdAt
    //
    // Collection: users/{userId}/favorites
    // Fields: userId, videoId, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "cadastro.lucas@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidRequest(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.businessName is string && data.businessName.size() > 0 && data.businessName.size() < 100 &&
             data.email is string && data.whatsapp is string &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();

      match /favorites/{favoriteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isOwner(userId);
      }
    }

    match /episodes/{episodeId} {
      allow read: if isAdmin() || resource.data.isPrivate == false || !('isPrivate' in resource.data);
      allow write: if isAdmin();
    }

    match /businesses/{businessId} {
      allow read: if true; // Publicly readable for discovery
      allow write: if isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if true; // Publicly readable for discovery
      allow write: if isAdmin();
    }

    match /commercialRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if isValidRequest(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
